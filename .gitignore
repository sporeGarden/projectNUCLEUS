# Operational artifacts (generated by cron, not documentation)
validation/baselines/cron.log
validation/baselines/daily/*.csv
validation/baselines/daily/*.txt
# membrane_7day.toml IS committed — it's the canonical state snapshot

# Python
__pycache__/
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Build artifacts
**/target/

# Test results
deploy/tier_test_results/

# Provenance run stdout logs (regenerable, keep manifests + braids)
validation/provenance-run-*/*.stdout

# Archived provenance runs (fossil record on disk, not in git)
validation/archive/provenance-run-*/

# Generated external validation directories (timestamped by external_validation.sh)
validation/external-*/

# Generated membrane provenance runs (timestamped by membrane_provenance.sh)
validation/membrane-provenance-*/

# Generated security validation runs (archived manually when complete)
validation/security-*/

# benchScale timestamped reports (committed selectively)
infra/benchScale/reports/

# Editor backup files
*.bak
*.orig
*.rej
